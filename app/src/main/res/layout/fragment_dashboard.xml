<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_light"
    tools:context=".ui.fragments.DashboardFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Welcome Section -->
        <TextView
            android:id="@+id/tv_welcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Welcome Back!"
            style="@style/TextAppearance.Title"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Keep up with your study goals"
            style="@style/TextAppearance.Subtitle"
            android:layout_marginBottom="24dp" />

        <!-- Progress Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <!-- Average Score Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_average_score"
                        android:textSize="14sp"
                        android:textColor="@color/gray_medium"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_average_score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/purple_500" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Study Time Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_study_time"
                        android:textSize="14sp"
                        android:textColor="@color/gray_medium"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_study_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 hours"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/success" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Due Flashcards Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_due_flashcards"
                        android:textSize="14sp"
                        android:textColor="@color/gray_medium"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_due_flashcards"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/info" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_start_quiz"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/button_start_quiz"
                android:textAllCaps="false"
                android:layout_marginBottom="12dp"
                style="@style/Button.Primary" />

            <Button
                android:id="@+id/btn_review_flashcards"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/button_review_flashcards"
                android:textAllCaps="false"
                android:layout_marginBottom="12dp"
                style="@style/Button.Primary" />

            <Button
                android:id="@+id/btn_weak_areas"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/button_weak_areas"
                android:textAllCaps="false"
                style="@style/Button.Primary" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
